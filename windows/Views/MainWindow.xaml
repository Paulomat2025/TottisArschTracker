<Window x:Class="ArtTimeTracker.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ArtTimeTracker.Windows.ViewModels"
        xmlns:v="clr-namespace:ArtTimeTracker.Windows.Views"
        Title="{Binding WindowTitle}" Width="900" Height="620"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
>
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArtworkDetailViewModel}">
            <v:ArtworkDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <v:StatisticsView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Native StatusBar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Content="{Binding StatusText}"/>
            <StatusBarItem DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button Command="{Binding ToggleAutoTrackingCommand}" Padding="6,2"
                        Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Red"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutoTracking}" Value="True">
                                            <Setter Property="Fill" Value="Green"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Auto-Tracking" FontSize="11"/>
                    </StackPanel>
                </Button>
            </StatusBarItem>
        </StatusBar>

        <!-- Sidebar with Griddy Icons -->
        <Border DockPanel.Dock="Left" Width="170" BorderThickness="0,0,1,0"
                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                Background="{x:Static SystemColors.ControlBrush}" Padding="4">
            <StackPanel>
                <TextBlock Text="💩 Tottis Arsch Tracker" FontWeight="Bold" FontSize="13" Margin="8,8,8,16"
                           TextWrapping="Wrap"/>

                <Button Command="{Binding NavigateToDashboardCommand}" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Padding="10,8" Margin="0,2" Background="Transparent"
                        BorderThickness="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" >
                        <Path Data="{StaticResource IconHome}" Fill="{x:Static SystemColors.ControlTextBrush}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateToStatisticsCommand}" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Padding="10,8" Margin="0,2" Background="Transparent"
                        BorderThickness="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" >
                        <Path Data="{StaticResource IconChartBar}" Fill="{x:Static SystemColors.ControlTextBrush}"
                              Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="Statistiken" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding QuitAppCommand}" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Padding="10,8" Margin="0,16,0,2" Background="Transparent"
                        BorderThickness="0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontWeight="Bold" Width="16" TextAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{x:Static SystemColors.ControlTextBrush}"/>
                        <TextBlock Text="Beenden" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ContentPresenter Content="{Binding CurrentView}" Margin="12"/>
    </DockPanel>
</Window>
